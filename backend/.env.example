# Gmail SMTP: works locally and on paid Render services.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_FAMILY=4

# Render Free blocks SMTP ports 25, 465, and 587. Use HTTPS there instead:
# MAIL_PROVIDER=brevo
# BREVO_API_KEY=your-brevo-api-key
